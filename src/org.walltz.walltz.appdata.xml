<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.walltz.walltz</id>
  <name>Walltz</name>
  <summary>Create wallpapers from images with blur and color backgrounds</summary>
  <description>
    <p>Walltz creates wallpapers from your images by producing a zoomed,
    blurred background with the original image overlaid. It supports both
    blur and solid color background modes, batch processing, and automatic
    color extraction from images.</p>
  </description>
  <categories>
    <category>Graphics</category>
  </categories>
  <url type="homepage">https://github.com/pavel/walltz</url>
  <project_license>GPL-3.0-or-later</project_license>
  <developer_name>Pavel</developer_name>
  <metadata_license>CC0-1.0</metadata_license>
  <content_rating type="oars-1.1"/>
  <releases>
    <release version="0.1.0" date="2026-07-19">
      <description>
        <p>Initial release</p>
        <ul>
          <li>Drop single or multiple images</li>
          <li>Blur and color background modes</li>
          <li>Auto color extraction from image</li>
          <li>Manual color picker</li>
          <li>Batch processing with progress</li>
          <li>Output saved as .wp.png</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
